rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // Acceso restringido exclusivamente a los correos de administración de élite
      allow read, write: if request.auth.token.email in ['munozmartinez.ismael@gmail.com', 'synqaisports@gmail.com'];
    }
  }
}